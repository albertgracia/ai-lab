---
import Layout from "../../layouts/Layout.astro";

let sections = [];
let generatedAt = null;

try {
  const response = await fetch(new URL("/api/knowledge.json", Astro.url));
  const data = await response.json();

  sections = Array.isArray(data.sections)
    ? data.sections
    : [];

  generatedAt = data.generated_at;

} catch (error) {
  console.error("Knowledge API unavailable", error);
}

const categoryStyles = {
  operations: "border-cyan-500/30 bg-cyan-500/10 text-cyan-300",
  infrastructure: "border-emerald-500/30 bg-emerald-500/10 text-emerald-300",
  architecture: "border-purple-500/30 bg-purple-500/10 text-purple-300",
  telemetry: "border-yellow-500/30 bg-yellow-500/10 text-yellow-300",
  recovery: "border-red-500/30 bg-red-500/10 text-red-300",
  knowledge: "border-zinc-500/30 bg-zinc-500/10 text-zinc-300",
};
---

<Layout title="Knowledge Hub · AI-LAB">

  <section class="space-y-10">

    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-10">

      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">
        AI-LAB KNOWLEDGE SYSTEM
      </p>

      <h1 class="mt-5 text-6xl font-black text-white">
        Knowledge Hub
      </h1>

      <p class="mt-6 max-w-5xl text-xl leading-9 text-zinc-300">
        Portal centralizado de documentación operacional, arquitectura,
        telemetría, runbooks e inteligencia técnica del AI-LAB.
      </p>

      {generatedAt && (
        <p class="mt-8 text-xs text-zinc-500">
          Generated: {generatedAt}
        </p>
      )}

    </header>

    <section class="grid gap-6 lg:grid-cols-2">

      {sections.map((section) => (

        <a
          href={section.href}
          class="group rounded-3xl border border-cyan-500/20 bg-zinc-950/80 p-8 transition hover:border-cyan-400/50 hover:bg-cyan-950/10"
        >

          <div class="flex items-start justify-between gap-4">

            <div>

              <span class={`rounded-full border px-3 py-1 text-xs font-bold ${categoryStyles[section.category] ?? categoryStyles.knowledge}`}>
                {section.category}
              </span>

              <h2 class="mt-5 text-3xl font-black text-white group-hover:text-cyan-300">
                {section.title}
              </h2>

            </div>

            <div class="text-3xl text-cyan-400">
              →
            </div>

          </div>

          <p class="mt-6 text-base leading-7 text-zinc-400">
            {section.description}
          </p>

        </a>

      ))}

    </section>

    <section class="rounded-3xl border border-cyan-500/20 bg-black/40 p-8">

      <h2 class="text-3xl font-black text-white">
        AI-LAB Operational Vision
      </h2>

      <div class="mt-6 grid gap-6 lg:grid-cols-3">

        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-xl font-bold text-white">
            Observability
          </h3>

          <p class="mt-4 text-sm leading-6 text-zinc-400">
            Telemetría viva, histórico GPU/VRAM, estado operacional y métricas internas.
          </p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-xl font-bold text-white">
            Infrastructure
          </h3>

          <p class="mt-4 text-sm leading-6 text-zinc-400">
            Inventario de nodos IA, gateways, servicios y arquitectura operacional.
          </p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-xl font-bold text-white">
            Operational Knowledge
          </h3>

          <p class="mt-4 text-sm leading-6 text-zinc-400">
            Runbooks, incidentes, recovery y memoria técnica centralizada.
          </p>
        </div>

      </div>

    </section>

  </section>

</Layout>
