---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Blog Técnico · AI-LAB">
  <div class="space-y-6">
    <h1 class="text-4xl font-bold text-cyan-400">Blog Técnico</h1>
    <p class="text-zinc-400">Diario de desarrollo, avances, pruebas y aprendizaje del laboratorio.</p>

    <div class="grid gap-6">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, "")}`} class="block rounded-xl border border-zinc-800 bg-zinc-900 p-6 hover:border-cyan-500 transition">
          <p class="text-sm text-zinc-500">{post.data.date}</p>
          <h2 class="mt-2 text-2xl font-semibold">{post.data.title}</h2>
          <p class="mt-2 text-zinc-400">{post.data.summary}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
