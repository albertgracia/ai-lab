---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="AI-LAB NOC">

<section class="space-y-10">

  <div>
    <p class="uppercase tracking-[0.3em] text-cyan-400 text-sm">AI-LAB NOC</p>
    <h1 class="mt-4 text-5xl font-black text-white">Runtime Operations Dashboard</h1>
    <p class="mt-4 max-w-4xl text-xl text-zinc-400">
      Observabilidad viva del laboratorio IA distribuido.
    </p>
  </div>

  <section class="grid gap-4 md:grid-cols-4">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
      <p class="text-sm text-zinc-500">Router API</p>
      <p id="router-status" class="mt-3 text-3xl font-black text-cyan-400">--</p>
    </div>

    <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
      <p class="text-sm text-zinc-500">GPU Nodes</p>
      <p id="gpu-count" class="mt-3 text-3xl font-black text-cyan-400">--</p>
    </div>

    <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
      <p class="text-sm text-zinc-500">Docker Containers</p>
      <p id="docker-count" class="mt-3 text-3xl font-black text-cyan-400">--</p>
    </div>

    <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
      <p class="text-sm text-zinc-500">Last Snapshot</p>
      <p id="snapshot-time" class="mt-3 text-lg font-bold text-emerald-400">--</p>
    </div>
  </section>

  <section>
    <h2 class="text-3xl font-bold text-white">GPU Runtime</h2>
    <div id="gpu-grid" class="mt-6 grid gap-6 md:grid-cols-2"></div>
  </section>

  <section>
    <h2 class="text-3xl font-bold text-white">LM Studio Nodes</h2>
    <div id="services-grid" class="mt-6 grid gap-4 md:grid-cols-3"></div>
  </section>

</section>

<script>
async function loadDashboard() {
  try {
    const res = await fetch("/api/status.json", { cache: "no-store" });
    const data = await res.json();

    const gpu = Array.isArray(data.gpu) ? data.gpu : [];
    const docker = Array.isArray(data.docker?.containers) ? data.docker.containers : [];
    const lmstudio = Array.isArray(data.llm?.lmstudio_nodes) ? data.llm.lmstudio_nodes : [];

    const gpuOnline = gpu.filter((n) => !(n.gpu_usage?.error || n.vram?.error)).length;
    const dockerRunning = docker.filter((c) => c.State === "running").length;

    document.getElementById("router-status").textContent = "ONLINE";
    document.getElementById("gpu-count").textContent = `${gpuOnline}/${gpu.length}`;
    document.getElementById("docker-count").textContent = `${dockerRunning}/${docker.length}`;
    document.getElementById("snapshot-time").textContent = new Date().toLocaleTimeString();

    const gpuGrid = document.getElementById("gpu-grid");
    gpuGrid.innerHTML = "";

    gpu.forEach((node) => {
      const online = !(node.gpu_usage?.error || node.vram?.error);
      const usage = online ? (node.gpu_usage?.max_gpu_usage_percent ?? 0).toFixed(2) : "--";
      const vramUsed = online ? (node.vram?.vram_used_gib ?? "--") : "--";
      const vramTotal = online ? (node.vram?.vram_total_gib ?? "--") : "--";
      const vramFree = online ? (node.vram?.vram_free_gib_estimated ?? "--") : "--";

      gpuGrid.innerHTML += `
        <div class="rounded-2xl border ${online ? "border-zinc-800" : "border-red-900/60"} bg-zinc-900 p-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-2xl font-bold text-cyan-400">${node.node}</h3>
              <p class="mt-1 text-zinc-500">${node.host}</p>
            </div>

            <div class="flex items-center gap-2 ${online ? "text-emerald-400" : "text-red-400"} font-bold">
              <div class="h-2 w-2 rounded-full ${online ? "bg-emerald-400 animate-pulse" : "bg-red-400"}"></div>
              ${online ? "ONLINE" : "OFFLINE"}
            </div>
          </div>

          <div class="mt-6 grid grid-cols-3 gap-4">
            <div>
              <p class="text-sm text-zinc-500">GPU</p>
              <p class="mt-2 text-3xl font-black text-white">${usage}%</p>
            </div>

            <div>
              <p class="text-sm text-zinc-500">VRAM</p>
              <p class="mt-2 text-3xl font-black text-white">${vramUsed} GiB</p>
              <p class="text-xs text-zinc-500">total ${vramTotal} · free ${vramFree}</p>
            </div>

            <div>
              <p class="text-sm text-zinc-500">Estado</p>
              <p class="mt-2 text-3xl font-black ${online ? "text-emerald-400" : "text-red-400"}">
                ${online ? "OK" : "DOWN"}
              </p>
            </div>
          </div>

          ${!online ? `<p class="mt-5 text-sm text-red-400">${node.gpu_usage?.error || node.vram?.error}</p>` : ""}
        </div>
      `;
    });

    const servicesGrid = document.getElementById("services-grid");
    servicesGrid.innerHTML = "";

    lmstudio.forEach((node) => {
      const online = Boolean(node.online);
      const models = Array.isArray(node.models) ? node.models : [];

      servicesGrid.innerHTML += `
        <div class="rounded-xl border ${online ? "border-zinc-800" : "border-red-900/60"} bg-zinc-900 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-bold text-white">${node.node}</p>
              <p class="text-sm text-zinc-500">LM Studio Node</p>
            </div>

            <div class="${online ? "text-emerald-400" : "text-red-400"} font-bold">
              ${online ? "ONLINE" : "OFFLINE"}
            </div>
          </div>

          ${
            online
              ? `<div class="mt-4 space-y-2">${models.map((m) => `<div class="rounded-lg bg-zinc-950 px-3 py-2 text-sm text-zinc-300">${m}</div>`).join("")}</div>`
              : `<p class="mt-4 text-sm text-red-400">No disponible</p>`
          }
        </div>
      `;
    });

  } catch (err) {
    console.error(err);
    document.getElementById("router-status").textContent = "OFFLINE";
    document.getElementById("router-status").className = "mt-3 text-3xl font-black text-red-400";
  }
}

loadDashboard();
setInterval(loadDashboard, 5000);
</script>

</Layout>
