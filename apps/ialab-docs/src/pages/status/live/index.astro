---
import Layout from "../../../layouts/Layout.astro";
import ClusterHealth from "../../../components/ClusterHealth.astro";
import EventStream from "../../../components/EventStream.astro";
---

<Layout title="Estado Vivo · AI-LAB">
  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="mb-8">
      <h1 class="text-5xl font-black tracking-tight text-white">Estado Vivo del AI-LAB</h1>
      <p class="mt-4 max-w-4xl text-lg text-zinc-400">
        Monitorizacion en tiempo real via eventos SSE.
      </p>
    </div>
    <ClusterHealth />
    <div class="mt-8">
      <EventStream />
    </div>
  </section>
</Layout>
