---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Estado · AI-LAB">

<h1 class="text-4xl font-bold text-cyan-400">
  Estado del LAB
</h1>

<div class="grid md:grid-cols-3 gap-6 mt-10">

  <div class="border border-zinc-800 rounded-xl p-6 bg-zinc-900">
    <h2 class="font-semibold">Router</h2>
    <p class="text-zinc-400 mt-2">
      AI-LAB Router API operativo
    </p>
  </div>

  <div class="border border-zinc-800 rounded-xl p-6 bg-zinc-900">
    <h2 class="font-semibold">GPU Nodes</h2>
    <p class="text-zinc-400 mt-2">
      RX9070XT / RX7900XT
    </p>
  </div>

  <div class="border border-zinc-800 rounded-xl p-6 bg-zinc-900">
    <h2 class="font-semibold">Docker Stack</h2>
    <p class="text-zinc-400 mt-2">
      Traefik, Qdrant, Open WebUI, Ollama, Portainer
    </p>
  </div>

</div>

</Layout>
