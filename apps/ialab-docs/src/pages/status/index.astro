---
import Layout from "../../layouts/Layout.astro";

const sections = [
  {
    title: "Live Infrastructure",
    description: "Estado operacional del stack AI-LAB, servicios, Docker, red UniFi y runtime.",
    href: "/status/live/",
    tag: "LIVE STATUS",
  },
  {
    title: "Historical Telemetry",
    description: "Análisis temporal, métricas históricas, tendencias y evolución del laboratorio.",
    href: "/status/history/",
    tag: "TIME SERIES",
  },
  {
    title: "Observability",
    description: "Dashboards Grafana, Prometheus, Loki, Alloy, Node Exporter, cAdvisor y Unpoller.",
    href: "/observability/",
    tag: "GRAFANA STACK",
  },
  {
    title: "Operations Center",
    description: "Runbooks, incidentes, operación interna, recuperación y procedimientos técnicos.",
    href: "/ops/",
    tag: "OPERATIONS",
  },
];

const kpis = [
  ["Cluster Status", "Healthy", "text-emerald-400"],
  ["GPU Nodes", "2", "text-cyan-400"],
  ["LLM Runtime", "Active", "text-orange-400"],
  ["Containers", "9", "text-white"],
];
---

<Layout title="Status · AI-LAB">
  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="mb-10">
      <div class="mb-4 inline-flex rounded-full border border-cyan-500/30 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-400">
        RUNTIME OBSERVABILITY
      </div>

      <h1 class="mb-4 text-5xl font-black tracking-tight text-white">
        Status Hub del AI-LAB
      </h1>

      <p class="max-w-4xl text-lg text-zinc-400">
        Centro de estado, telemetría e indicadores operacionales del laboratorio AI-LAB.
        Desde aquí se accede al estado vivo, histórico de telemetría,
        observabilidad avanzada y operaciones internas.
      </p>

      <div class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900/80 px-5 py-4 text-sm text-zinc-400">
        <span class="font-bold text-emerald-400">LIVE</span>
        · última actualización visual: snapshot local · GPUs: 2 · LLM nodes: 3 · containers: 9
      </div>
    </div>

    <div class="mb-12 grid gap-6 md:grid-cols-4">
      {
        kpis.map(([label, value, color]) => (
          <div class="rounded-2xl border border-zinc-800 bg-zinc-900/70 p-6 shadow-xl shadow-black/20">
            <div class="text-sm text-zinc-500">{label}</div>
            <div class={`mt-2 text-4xl font-black ${color}`}>
              {value}
            </div>
          </div>
        ))
      }
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="group rounded-2xl border border-zinc-800 bg-zinc-900/70 p-8 shadow-xl shadow-black/20 transition hover:border-cyan-500/40 hover:bg-zinc-900"
          >
            <div class="mb-4 inline-flex rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 text-xs font-bold tracking-widest text-cyan-400">
              {section.tag}
            </div>

            <h2 class="mb-4 text-3xl font-black text-white group-hover:text-cyan-400">
              {section.title}
            </h2>

            <p class="min-h-16 text-zinc-400">
              {section.description}
            </p>

            <div class="mt-6 text-sm font-bold tracking-wide text-cyan-400">
              OPEN →
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
