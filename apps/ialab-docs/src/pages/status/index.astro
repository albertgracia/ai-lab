---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Estado Vivo · AI-LAB">
  <section class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-10">
    <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">Public Status</p>
    <h1 class="mt-6 text-5xl font-black text-white">Estado Vivo</h1>
    <p class="mt-6 max-w-4xl text-xl text-zinc-300">
      La telemetría en tiempo real se mantiene privada. La versión pública expone
      una vista segura del laboratorio y su arquitectura.
    </p>
  </section>
</Layout>
