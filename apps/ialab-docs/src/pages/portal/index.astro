---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="AI-LAB · Operations Portal">
  <section class="space-y-10">
    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-10">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB PRIVATE PORTAL</p>
      <h1 class="mt-5 text-6xl font-black text-white">AI-LAB Operations Portal</h1>
      <p class="mt-6 max-w-5xl text-xl leading-9 text-zinc-300">
        Centro privado de operaciones, telemetría, arquitectura, modelos IA, runbooks e infraestructura.
      </p>
    </header>

    <section class="grid gap-5 lg:grid-cols-3">
      <a href="/ops" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Operations Center →</a>
      <a href="/knowledge" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Knowledge Hub →</a>
      <a href="https://metricas.labrazahome.com/runtime" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Historical Telemetry →</a>
      <a href="/infra" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Infrastructure →</a>
      <a href="/models" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Model Registry →</a>
      <a href="/runbooks" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">Runbooks →</a>
    </section>
  </section>
</Layout>
