---
import Layout from "../../layouts/Layout.astro";

const runbooks = [
  {
    title: "Cloudflare Tunnel Recovery",
    status: "ready",
    href: "/runbooks/cloudflare-tunnel-recovery",
    description: "Recuperación del acceso privado cuando falla el túnel Cloudflare.",
  },
  {
    title: "Astro Build Recovery",
    status: "ready",
    href: "/runbooks/astro-build-recovery",
    description: "Diagnóstico y recuperación cuando falla el build del portal AI-LAB.",
  },
  {
    title: "Telemetry Recovery",
    status: "ready",
    href: "/runbooks/telemetry-recovery",
    description: "Recuperación de páginas /status, /status/live y /status/history.",
  },
];
---

<Layout title="Runbooks · AI-LAB">
  <section class="space-y-10">
    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-8">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB OPERATIONS</p>
      <h1 class="mt-5 text-5xl font-black text-white">Runbooks</h1>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-zinc-300">
        Procedimientos operativos para diagnóstico, recuperación y continuidad del laboratorio.
      </p>
    </header>

    <div class="grid gap-5 lg:grid-cols-3">
      {runbooks.map((item) => (
        <a href={item.href} class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 transition hover:border-cyan-400">
          <p class="text-xs uppercase tracking-[0.25em] text-emerald-300">{item.status}</p>
          <h2 class="mt-4 text-2xl font-bold text-white">{item.title}</h2>
          <p class="mt-4 text-sm leading-6 text-zinc-400">{item.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
