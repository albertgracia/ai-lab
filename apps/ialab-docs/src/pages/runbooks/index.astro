---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const runbooks = await getCollection("runbooks");
---

<Layout title="Runbooks · AI-LAB">
  <div class="space-y-6">
    <h1 class="text-4xl font-bold text-cyan-400">
      Runbooks Operativos
    </h1>

    <p class="text-zinc-400">
      Procedimientos seguros para operar y recuperar servicios del AI-LAB.
    </p>

    <div class="grid gap-6">
      {
        runbooks.map((runbook) => (
          <a
            href={`/runbooks/${runbook.id.replace(/\.md$/, "")}`}
            class="block rounded-xl border border-zinc-800 bg-zinc-900 p-6 transition hover:border-cyan-500"
          >
            <p class="text-xs uppercase text-amber-400">
              {runbook.data.severity}
            </p>

            <h2 class="mt-2 text-2xl font-semibold text-white">
              {runbook.data.title}
            </h2>

            <p class="mt-2 text-zinc-400">
              {runbook.data.summary}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
