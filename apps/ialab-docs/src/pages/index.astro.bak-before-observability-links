---
import Layout from "../layouts/Layout.astro";
import HomeLiveStats from "../components/HomeLiveStats.astro";

const skills = [
  "Linux Server",
  "Windows Server",
  "systemd",
  "LVM",
  "Docker",
  "Docker Compose",
  "Traefik",
  "Cloudflare Tunnel",
  "Cloudflare Zero Trust",
  "DNS",
  "SSH",
  "Reverse Proxy",
  "FastAPI",
  "Uvicorn",
  "Python",
  "Bash",
  "Git",
  "Astro",
  "Tailwind",
  "React",
  "Recharts",
  "Mermaid",
  "Qdrant",
  "RAG",
  "Embeddings",
  "LLMs locales",
  "LM Studio",
  "OpenAI-compatible API",
  "GPU Nodes",
  "Observabilidad",
  "Historical Telemetry",
  "Runbooks",
  "Troubleshooting",
  "Documentación técnica",
];

const highlights = [
  {
    title: "AI Infrastructure",
    text: "Diseño y operación de una plataforma IA local con router OpenAI-compatible, GPUs remotas, observabilidad y documentación viva.",
  },
  {
    title: "Systems Engineering",
    text: "Administración Linux/Windows, systemd, LVM, servicios persistentes, troubleshooting y operación de infraestructura real.",
  },
  {
    title: "Secure Self-Hosting",
    text: "Publicación segura con Cloudflare Access, Tunnel, Traefik y Zero Trust sin abrir puertos entrantes al homelab.",
  },
];

const projects = [
  {
    name: "AI-LAB Platform",
    desc: "Infraestructura local de IA distribuida con portal Astro, runtime persistente, router IA y dashboard vivo.",
    href: "/architecture",
  },
  {
    name: "Historical Telemetry",
    desc: "Snapshots históricos, API de telemetría y gráficas con React/Recharts para observar evolución GPU y runtime.",
    href: "/status/history",
  },
  {
    name: "Secure Publishing",
    desc: "Dominio público protegido con Cloudflare Access, Tunnel y Traefik como gateway interno.",
    href: "/architecture/security",
  },
];
---

<Layout title="Albert · AI Infrastructure Engineer">

<section class="space-y-16">

  <section class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black p-10 shadow-2xl shadow-cyan-950/20">
    <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">
      Técnico de Sistemas · AI Infrastructure Builder
    </p>

    <h1 class="mt-6 max-w-5xl text-5xl font-black leading-tight text-white md:text-7xl">
      Diseño, despliego y documento infraestructuras IT modernas.
    </h1>

    <p class="mt-6 max-w-4xl text-xl leading-relaxed text-zinc-300">
      Especializado en sistemas, redes, contenedores, automatización, self-hosting seguro
      y plataformas locales de inteligencia artificial con observabilidad real.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/architecture" class="rounded-xl bg-cyan-400 px-6 py-3 font-bold text-zinc-950 hover:bg-cyan-300">
        Ver arquitectura
      </a>

      <a href="/status" class="rounded-xl border border-zinc-700 px-6 py-3 font-bold text-zinc-200 hover:border-cyan-400 hover:text-cyan-400">
        Estado vivo del LAB
      </a>

      <a href="/projects" class="rounded-xl border border-zinc-700 px-6 py-3 font-bold text-zinc-200 hover:border-cyan-400 hover:text-cyan-400">
        Proyectos técnicos
      </a>
    </div>
  </section>

  <section class="grid gap-6 md:grid-cols-3">
    {
      highlights.map((item) => (
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
          <h2 class="text-2xl font-bold text-cyan-400">{item.title}</h2>
          <p class="mt-4 leading-relaxed text-zinc-400">{item.text}</p>
        </div>
      ))
    }
  </section>

  <HomeLiveStats />

  <section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-8">
    <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">
      Proyecto principal
    </p>

    <h2 class="mt-4 text-4xl font-black text-white">
      AI-LAB · Plataforma IA distribuida
    </h2>

    <p class="mt-5 max-w-5xl text-lg leading-relaxed text-zinc-300">
      AI-LAB es una plataforma local de experimentación y operación IA que integra
      inferencia distribuida, GPUs remotas, router OpenAI-compatible, observabilidad histórica,
      documentación viva, almacenamiento persistente y publicación segura mediante Zero Trust.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-4">
      <div class="rounded-xl bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Nodo principal</p>
        <p class="mt-2 font-semibold text-white">ubuntu-ialab</p>
        <p class="text-zinc-400">192.168.1.30</p>
      </div>

      <div class="rounded-xl bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">GPU Nodes</p>
        <p class="mt-2 font-semibold text-white">RX9070XT</p>
        <p class="text-zinc-400">RX7900XT</p>
      </div>

      <div class="rounded-xl bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Gateway</p>
        <p class="mt-2 font-semibold text-white">Traefik</p>
        <p class="text-zinc-400">Cloudflare Tunnel</p>
      </div>

      <div class="rounded-xl bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Observabilidad</p>
        <p class="mt-2 font-semibold text-white">Snapshots vivos</p>
        <p class="text-zinc-400">Telemetry histórica</p>
      </div>
    </div>
  </section>

  <section>
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">
          Aptitudes técnicas
        </p>

        <h2 class="mt-3 text-4xl font-black text-white">
          Stack y competencias
        </h2>
      </div>

      <a href="/skills" class="hidden rounded-xl border border-zinc-700 px-5 py-3 font-bold text-zinc-200 hover:border-cyan-400 hover:text-cyan-400 md:block">
        Ver skills
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        skills.map((skill) => (
          <span class="rounded-full border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-300">
            {skill}
          </span>
        ))
      }
    </div>
  </section>

  <section class="grid gap-6 md:grid-cols-3">
    {
      projects.map((project) => (
        <a href={project.href} class="block rounded-2xl border border-zinc-800 bg-zinc-900 p-6 transition hover:border-cyan-500 hover:bg-zinc-900/80">
          <h2 class="text-2xl font-bold text-cyan-400">{project.name}</h2>
          <p class="mt-4 leading-relaxed text-zinc-400">{project.desc}</p>
        </a>
      ))
    }
  </section>

  <section class="rounded-2xl border border-zinc-800 bg-zinc-900 p-8">
    <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">
      Perfil profesional
    </p>

    <h2 class="mt-4 text-4xl font-black text-white">
      Técnico de Sistemas con enfoque en plataformas modernas
    </h2>

    <p class="mt-5 max-w-5xl text-lg leading-relaxed text-zinc-300">
      Combino administración de sistemas, redes, automatización y documentación técnica con
      integración de herramientas actuales de IA. Trabajo construyendo entornos mantenibles,
      observables y seguros, priorizando operación real, troubleshooting y claridad arquitectónica.
    </p>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <div>
        <p class="text-sm uppercase tracking-wide text-cyan-400">Operación</p>
        <p class="mt-2 text-zinc-400">Servicios persistentes, runbooks, systemd, logs y recuperación.</p>
      </div>

      <div>
        <p class="text-sm uppercase tracking-wide text-cyan-400">Infraestructura</p>
        <p class="mt-2 text-zinc-400">Docker, Traefik, Cloudflare, DNS, storage LVM y reverse proxy.</p>
      </div>

      <div>
        <p class="text-sm uppercase tracking-wide text-cyan-400">IA aplicada</p>
        <p class="mt-2 text-zinc-400">LLMs locales, GPUs remotas, Qdrant, RAG, telemetry y routing IA.</p>
      </div>
    </div>
  </section>

</section>

</Layout>
