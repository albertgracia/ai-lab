---
import Layout from "../../layouts/Layout.astro";

let nodes = [];
let generatedAt = null;

try {
  const response = await fetch(new URL("/api/infra.json", Astro.url));
  const data = await response.json();

  nodes = Array.isArray(data.nodes)
    ? data.nodes
    : [];

  generatedAt = data.generated_at;

} catch (error) {
  console.error("Infra API unavailable", error);
}
---

<Layout title="Infrastructure · AI-LAB">

  <section class="space-y-10">

    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-8">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">
        AI-LAB INFRASTRUCTURE
      </p>

      <h1 class="mt-5 text-5xl font-black text-white">
        Infrastructure Inventory
      </h1>

      <p class="mt-4 max-w-4xl text-lg leading-8 text-zinc-300">
        Inventario operacional de nodos, GPUs, gateways y servicios del laboratorio.
      </p>

      {generatedAt && (
        <p class="mt-6 text-xs text-zinc-500">
          Generated: {generatedAt}
        </p>
      )}
    </header>

    <div class="grid gap-6 lg:grid-cols-2">

      {nodes.map((node) => (

        <article class="rounded-3xl border border-cyan-500/20 bg-zinc-950/80 p-7">

          <div class="flex items-start justify-between gap-4">

            <div>
              <p class="text-xs uppercase tracking-[0.25em] text-cyan-400">
                {node.role}
              </p>

              <h2 class="mt-3 text-3xl font-black text-white">
                {node.name}
              </h2>
            </div>

            <span class="rounded-full border border-emerald-500/40 bg-emerald-500/10 px-3 py-1 text-xs font-bold text-emerald-300">
              {node.status}
            </span>

          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-2">

            <div class="rounded-2xl border border-zinc-800 bg-black/30 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                IP Address
              </p>

              <p class="mt-2 font-mono text-cyan-300">
                {node.ip}
              </p>
            </div>

            <div class="rounded-2xl border border-zinc-800 bg-black/30 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                Operating System
              </p>

              <p class="mt-2 text-zinc-300">
                {node.os}
              </p>
            </div>

          </div>

          {node.gpu && (
            <div class="mt-6 rounded-2xl border border-cyan-500/20 bg-cyan-950/10 p-5">

              <p class="text-xs uppercase tracking-[0.2em] text-cyan-400">
                GPU
              </p>

              <div class="mt-3 flex items-center justify-between gap-4">
                <p class="text-lg font-bold text-white">
                  {node.gpu.model}
                </p>

                <p class="text-sm text-zinc-400">
                  {node.gpu.vram}
                </p>
              </div>

            </div>
          )}

          <div class="mt-6">

            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
              Services
            </p>

            <div class="mt-3 flex flex-wrap gap-2">
              {node.services.map((service) => (
                <span class="rounded-full border border-zinc-700 bg-black/30 px-3 py-1 text-xs text-zinc-300">
                  {service}
                </span>
              ))}
            </div>

          </div>

          <div class="mt-6 flex flex-wrap gap-2">

            {node.tags.map((tag) => (
              <span class="rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 text-xs text-cyan-300">
                #{tag}
              </span>
            ))}

          </div>

        </article>

      ))}

    </div>

  </section>

</Layout>
