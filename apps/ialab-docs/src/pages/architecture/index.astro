---
import Layout from "../../layouts/Layout.astro";

let layers = [];
let generatedAt = null;

try {
  const response = await fetch(new URL("/api/architecture.json", Astro.url));
  const data = await response.json();
  layers = Array.isArray(data.layers) ? data.layers : [];
  generatedAt = data.generated_at;
} catch (error) {
  console.error("Architecture API unavailable", error);
}
---

<Layout title="Architecture · AI-LAB">
  <section class="space-y-10">

    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950 p-8">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB BLUEPRINT</p>
      <h1 class="mt-5 text-5xl font-black text-white">Operational Architecture</h1>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-zinc-300">
        Mapa de arquitectura del portal AI-LAB: entrada segura, routing, aplicación,
        APIs operacionales, observabilidad y base de conocimiento.
      </p>

      {generatedAt && (
        <p class="mt-6 text-xs text-zinc-500">Generated: {generatedAt}</p>
      )}
    </header>

    <section class="rounded-3xl border border-cyan-500/20 bg-black/40 p-8">
      <h2 class="text-3xl font-black text-white">Flow Map</h2>

      <div class="mt-8 grid gap-4">
        {layers.map((layer, index) => (
          <div>
            <article class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  <p class="text-xs uppercase tracking-[0.25em] text-cyan-400">
                    Layer {index + 1}
                  </p>
                  <h3 class="mt-2 text-2xl font-bold text-white">{layer.name}</h3>
                  <p class="mt-3 text-sm leading-6 text-zinc-400">{layer.description}</p>
                </div>

                <div class="flex flex-wrap gap-2 lg:max-w-xl lg:justify-end">
                  {layer.components.map((component) => (
                    <span class="rounded-full border border-zinc-700 bg-black/40 px-3 py-1 text-xs text-zinc-300">
                      {component}
                    </span>
                  ))}
                </div>
              </div>
            </article>

            {index < layers.length - 1 && (
              <div class="flex justify-center py-2 text-2xl text-cyan-400">↓</div>
            )}
          </div>
        ))}
      </div>
    </section>

    <section class="grid gap-5 lg:grid-cols-3">
      <a href="/ops" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        Operations Center →
      </a>

      <a href="/infra" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        Infrastructure Inventory →
      </a>

      <a href="/runbooks" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        Runbooks →
      </a>
    </section>

  </section>
</Layout>
