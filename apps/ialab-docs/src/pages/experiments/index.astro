---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Experiments · AI-LAB">
  <section class="space-y-10">
    <div class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 to-black p-10">
      <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">Lab Experiments</p>
      <h1 class="mt-6 text-5xl font-black text-white">Experiments</h1>
      <p class="mt-6 max-w-4xl text-xl text-zinc-300">
        Pruebas, benchmarks, ideas, prototipos y experimentación técnica del laboratorio.
      </p>
    </div>
  </section>
</Layout>
