---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Research · AI-LAB">
  <section class="space-y-10">
    <div class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 to-black p-10">
      <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">AI-LAB Research</p>
      <h1 class="mt-6 text-5xl font-black text-white">Research</h1>
      <p class="mt-6 max-w-4xl text-xl text-zinc-300">
        Investigación aplicada en observabilidad, telemetría, análisis temporal e infraestructura cognitiva.
      </p>
    </div>
  </section>
</Layout>
