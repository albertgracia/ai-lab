---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Skills · AI-LAB">
  <section class="space-y-10">
    <div>
      <p class="uppercase tracking-[0.3em] text-cyan-400 text-sm">Technical Profile</p>
      <h1 class="mt-4 text-5xl font-black text-white">Habilidades técnicas</h1>
      <p class="mt-4 max-w-4xl text-xl text-zinc-400">
        Sistemas, infraestructura, automatización, seguridad y plataformas IA locales.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {[
        ["Sistemas", ["Linux Server", "Windows Server", "systemd", "SSH", "LVM", "Backups"]],
        ["Infraestructura", ["Docker", "Docker Compose", "Traefik", "Cloudflare Tunnel", "Zero Trust", "DNS"]],
        ["IA Local", ["LLMs", "LM Studio", "OpenAI-compatible API", "GPU Nodes", "Qdrant", "RAG"]],
        ["Automatización", ["Bash", "Python", "FastAPI", "Git", "Runbooks", "Observabilidad"]],
      ].map(([title, skills]) => (
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
          <h2 class="text-2xl font-bold text-cyan-400">{title}</h2>
          <div class="mt-5 flex flex-wrap gap-3">
            {skills.map((skill) => (
              <span class="rounded-full border border-zinc-700 bg-zinc-950 px-4 py-2 text-sm text-zinc-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
