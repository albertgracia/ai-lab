---
import Layout from "../../layouts/Layout.astro";
const LOCAL_API = "http://127.0.0.1:8083";
const PUBLIC_API = "https://blog-ai-lab.labrazahome.com";
const AUTH_HEADERS = {
  "CF-Access-Client-Id": "3093bf6c93d1c8dbb6ab65db21941ac0.access",
  "CF-Access-Client-Secret": "e54c05bb3496e0ff55c55b6af63c456aa6b7d5171a74f42aeebd3facefe30a1c"
};
---
<Layout title="Command History · AI-LAB">
  <section class="mx-auto max-w-7xl px-6 py-16 space-y-10">
    <header class="rounded-3xl border border-amber-500/30 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black p-10">
      <div class="flex items-start justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-amber-400">AI-LAB COMMAND PIPELINE</p>
          <h1 class="mt-3 text-5xl font-black text-white">Command History</h1>
          <p class="mt-4 max-w-4xl text-lg text-zinc-300">
            Propuestas de comandos del LLM, estado de aprobacion, resultados de ejecucion y auditoria.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-700 bg-zinc-900 px-6 py-5 text-center min-w-[140px]">
          <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Total</p>
          <p class="mt-1 text-3xl font-black text-amber-400" id="total-count">--</p>
          <p class="text-xs text-zinc-500" id="status-breakdown">cargando...</p>
        </div>
      </div>
    </header>

    <div class="space-y-4">
      <div class="flex flex-wrap gap-2" id="filter-tabs">
        <button class="filter-btn rounded-lg px-4 py-2 text-sm font-bold bg-amber-700 text-white" data-status="">Todas</button>
        <button class="filter-btn rounded-lg px-4 py-2 text-sm text-zinc-400 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800" data-status="pending">Pendientes</button>
        <button class="filter-btn rounded-lg px-4 py-2 text-sm text-zinc-400 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800" data-status="executed">Ejecutadas</button>
        <button class="filter-btn rounded-lg px-4 py-2 text-sm text-zinc-400 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800" data-status="failed">Falladas</button>
        <button class="filter-btn rounded-lg px-4 py-2 text-sm text-zinc-400 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800" data-status="rejected">Rechazadas</button>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
        <div id="commands-table">
          <div class="text-zinc-500 italic text-center py-8" id="loading-msg">Cargando historial...</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const LOCAL_API = "http://127.0.0.1:8083";
  const PUBLIC_API = "https://blog-ai-lab.labrazahome.com";
  const AUTH_HEADERS = {
    "CF-Access-Client-Id": "3093bf6c93d1c8dbb6ab65db21941ac0.access",
    "CF-Access-Client-Secret": "e54c05bb3496e0ff55c55b6af63c456aa6b7d5171a74f42aeebd3facefe30a1c"
  };

  function isPublic() {
    const h = window.location.hostname;
    return h === "ai-lab.labrazahome.com" || h.includes("pages.dev") || h.includes("cloudflare");
  }

  function apiBase() {
    return isPublic() ? PUBLIC_API : LOCAL_API;
  }

  async function apiGet(path) {
    const base = apiBase();
    const headers = isPublic() ? {} : AUTH_HEADERS;
    const url = base + path;
    const res = await fetch(url, { cache: "no-store", headers });
    return await res.json();
  }

  const STATUS_COLORS = {
    pending: { dot: "bg-yellow-400", label: "text-yellow-400" },
    executed: { dot: "bg-emerald-400", label: "text-emerald-400" },
    failed: { dot: "bg-red-500", label: "text-red-400" },
    rejected: { dot: "bg-zinc-500", label: "text-zinc-400" },
  };

  const RISK_COLORS = {
    low: "text-emerald-400",
    medium: "text-yellow-400",
    high: "text-red-400",
  };

  let allProposals = [];
  let currentFilter = "";

  function render() {
    const filtered = currentFilter
      ? allProposals.filter(p => p.status === currentFilter)
      : allProposals;

    const total = allProposals.length;
    document.getElementById("total-count").textContent = total;
    const breakdown = {
      pending: allProposals.filter(p => p.status === "pending").length,
      executed: allProposals.filter(p => p.status === "executed").length,
      failed: allProposals.filter(p => p.status === "failed").length,
      rejected: allProposals.filter(p => p.status === "rejected").length,
    };
    document.getElementById("status-breakdown").textContent =
      `${breakdown.pending} pend · ${breakdown.executed} ok · ${breakdown.failed} fail · ${breakdown.rejected} rej`;

    if (filtered.length === 0) {
      document.getElementById("commands-table").innerHTML =
        '<p class="text-zinc-500 italic text-center py-8">No hay comandos con este estado</p>';
      return;
    }

    let html = `<div class="space-y-2">`;
    for (const p of filtered) {
      const sc = STATUS_COLORS[p.status] || STATUS_COLORS.pending;
      const rc = RISK_COLORS[p.risk] || "text-zinc-400";
      const created = p.created_at ? new Date(p.created_at * 1000).toLocaleString() : "--";
      const approved = p.approved_at ? new Date(p.approved_at * 1000).toLocaleString() : "";
      const cmdShort = p.command.length > 60 ? p.command.slice(0, 60) + "..." : p.command;
      const resultOk = p.result?.success;
      const exitCode = p.result?.exit_code;

      html += `<div class="rounded-xl border border-zinc-800 bg-zinc-900 p-4 text-sm hover:border-zinc-700 transition-colors">
        <div class="flex items-center justify-between cursor-pointer toggle-detail" data-id="${p.id}">
          <div class="flex items-center gap-3 min-w-0 flex-1">
            <span class="inline-block w-2.5 h-2.5 rounded-full ${sc.dot} shrink-0"></span>
            <span class="${sc.label} text-xs font-mono uppercase shrink-0">${p.status}</span>
            <span class="text-zinc-300 font-mono truncate">${cmdShort}</span>
            <span class="text-zinc-500 text-xs shrink-0 ${rc}">${p.risk}</span>
          </div>
          <div class="flex items-center gap-4 shrink-0 ml-4">
            <span class="text-zinc-500 text-xs">${created}</span>
            ${p.reason ? `<span class="text-zinc-500 text-xs italic hidden md:inline">${p.reason}</span>` : ""}
            <span class="text-zinc-600 text-xs toggle-icon">▶</span>
          </div>
        </div>
        <div id="detail-${p.id}" class="hidden mt-3 pt-3 border-t border-zinc-800 text-xs space-y-2">
          <div class="grid grid-cols-2 gap-4">
            <div><span class="text-zinc-500">Comando:</span> <code class="text-zinc-200 ml-1">${p.command}</code></div>
            <div><span class="text-zinc-500">ID:</span> <span class="text-zinc-400 ml-1 font-mono">${p.id}</span></div>
            ${p.reason ? `<div><span class="text-zinc-500">Razon:</span> <span class="text-zinc-400 ml-1">${p.reason}</span></div>` : ""}
            ${approved ? `<div><span class="text-zinc-500">Aprobado:</span> <span class="text-zinc-400 ml-1">${approved}</span></div>` : ""}
          </div>
          ${p.result ? `
          <div class="mt-2 p-3 rounded-lg ${resultOk ? 'bg-emerald-950/40 border border-emerald-900/50' : 'bg-red-950/40 border border-red-900/50'}">
            <div class="flex gap-4 mb-1">
              <span class="${resultOk ? 'text-emerald-400' : 'text-red-400'} font-bold">${resultOk ? "EXIT 0" : "EXIT " + (exitCode ?? "?")}</span>
            </div>
            ${p.result.output ? `<pre class="text-zinc-300 mt-1 whitespace-pre-wrap max-h-24 overflow-y-auto">${p.result.output}</pre>` : ""}
            ${p.result.errors ? `<pre class="text-red-400 mt-1 whitespace-pre-wrap max-h-16 overflow-y-auto">${p.result.errors}</pre>` : ""}
          </div>` : `
          <div class="text-zinc-600 italic">Sin ejecutar</div>`}
        </div>
      </div>`;
    }
    html += `</div>`;
    document.getElementById("commands-table").innerHTML = html;

    document.querySelectorAll(".toggle-detail").forEach(el => {
      el.addEventListener("click", () => {
        const id = el.dataset.id;
        const detail = document.getElementById("detail-" + id);
        const icon = el.querySelector(".toggle-icon");
        if (detail) {
          const isHidden = detail.classList.contains("hidden");
          detail.classList.toggle("hidden");
          if (icon) icon.textContent = isHidden ? "▼" : "▶";
        }
      });
    });

    document.querySelectorAll(".filter-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".filter-btn").forEach(b => {
          b.className = "filter-btn rounded-lg px-4 py-2 text-sm text-zinc-400 bg-zinc-900 border border-zinc-800 hover:bg-zinc-800";
        });
        btn.className = "filter-btn rounded-lg px-4 py-2 text-sm font-bold bg-amber-700 text-white";
        currentFilter = btn.dataset.status;
        render();
      });
    });
  }

  document.addEventListener("DOMContentLoaded", async () => {
    const data = await apiGet("/api/commands/history?limit=200");
    allProposals = data.proposals || [];
    render();
  });
</script>
