---

import Layout from "../../layouts/Layout.astro";

const API_BASE = "https://blog-ai-lab.labrazahome.com";

---
<Layout title="Cognitive Memory · AI-LAB">
  <section class="mx-auto max-w-7xl px-6 py-16 space-y-10">
    <header class="rounded-3xl border border-purple-500/30 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black p-10">
      <div class="flex items-start justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-purple-400">AI-LAB COGNITIVE MEMORY</p>
          <h1 class="mt-3 text-5xl font-black text-white">Memory Recall</h1>
          <p class="mt-4 max-w-4xl text-lg text-zinc-300">
            Busqueda semantica sobre memoria cognitiva. Consulta routing history, snapshots cognitivos, incidentes y working memory persistente en Qdrant.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-700 bg-zinc-900 px-6 py-5 text-center min-w-[140px]">
          <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Qdrant Points</p>
          <p class="mt-1 text-3xl font-black text-purple-400" id="total-points">--</p>
          <p class="text-xs text-zinc-500" id="collections-count">6 colecciones</p>
        </div>
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-4 space-y-4">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-md font-bold text-purple-400 mb-4">Busqueda</h3>
          <input id="query-input" type="text" placeholder="Ej: error, latencia, codigo..." class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-3 text-sm text-white placeholder-zinc-500 focus:border-purple-500 focus:outline-none" />
          <div class="mt-3 flex gap-2">
            <select id="collection-select" class="flex-1 rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-white">
              <option value="routing_history">Routing History</option>
              <option value="cognitive_history">Cognitive History</option>
              <option value="incidents">Incidents</option>
              <option value="optimizer_history">Optimizer History</option>
              <option value="runtime_snapshots">Runtime Snapshots</option>
              <option value="working_memory">Working Memory</option>
            </select>
            <button id="search-btn" class="rounded-lg bg-purple-600 px-5 py-2 text-sm font-bold text-white hover:bg-purple-500">Buscar</button>
          </div>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-md font-bold text-emerald-400 mb-4">Recall Cruzado</h3>
          <p class="text-xs text-zinc-500 mb-3">Busca en routing + cognitive + incidents simultaneamente</p>
          <input id="recall-input" type="text" placeholder="Ej: fallo en gateway..." class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-3 text-sm text-white placeholder-zinc-500 focus:border-emerald-500 focus:outline-none" />
          <button id="recall-btn" class="mt-3 w-full rounded-lg bg-emerald-700 px-5 py-2 text-sm font-bold text-white hover:bg-emerald-600">Recall</button>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <h3 class="text-md font-bold text-red-400 mb-4">Incidentes</h3>
          <input id="incident-input" type="text" placeholder="Buscar incidentes..." class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-3 text-sm text-white placeholder-zinc-500 focus:border-red-500 focus:outline-none" />
          <select id="severity-select" class="mt-3 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-white">
            <option value="">Todas las severidades</option>
            <option value="critical">Critical</option>
            <option value="warning">Warning</option>
            <option value="info">Info</option>
          </select>
          <button id="incident-btn" class="mt-3 w-full rounded-lg bg-red-800 px-5 py-2 text-sm font-bold text-white hover:bg-red-700">Buscar Incidentes</button>
        </div>
      </div>

      <div class="lg:col-span-8 space-y-4" id="results-area">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-white" id="results-title">Resultados</h3>
            <span class="text-xs text-zinc-500" id="results-count">0</span>
          </div>
          <div id="results-list" class="space-y-3 max-h-[65vh] overflow-y-auto">
            <p class="text-zinc-500 italic">Haz una busqueda para ver resultados...</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const API_BASE = "https://blog-ai-lab.labrazahome.com";
  const AUTH_HEADERS = {
    "CF-Access-Client-Id": "3093bf6c93d1c8dbb6ab65db21941ac0.access",
    "CF-Access-Client-Secret": "e54c05bb3496e0ff55c55b6af63c456aa6b7d5171a74f42aeebd3facefe30a1c"
  };

  async function apiGet(path) {
    const isPublic = window.location.hostname === "ai-lab.labrazahome.com" || window.location.hostname.includes("pages.dev");
    const url = isPublic ? path : API_BASE + path;
    const headers = isPublic ? {} : AUTH_HEADERS;
    const res = await fetch(url, { cache: "no-store", headers });
    return await res.json();
  }

  function renderResults(data, title) {
    document.getElementById("results-title").textContent = title;
    document.getElementById("results-count").textContent = data.count || 0;
    const list = document.getElementById("results-list");
    if (!data.results || data.results.length === 0) {
      list.innerHTML = '<p class="text-zinc-500 italic">Sin resultados</p>';
      return;
    }
    list.innerHTML = data.results.map(r => {
      const p = r.payload || {};
      const coll = r.collection || "";
      const score = r.score ? Math.round(r.score * 100) + "%" : "--";
      const time = p.timestamp ? new Date(p.timestamp * 1000).toLocaleString() : "--";
      return `<div class="rounded-xl border border-zinc-800 bg-zinc-900 p-4 text-sm">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-mono text-purple-400">${coll}</span>
          <span class="text-xs text-zinc-500">${time}</span>
        </div>
        <div class="grid grid-cols-2 gap-2 text-xs">
          ${Object.entries(p).filter(([k]) => !["timestamp","schema_version","event_type"].includes(k)).map(([k, v]) => `<div><span class="text-zinc-500">${k}:</span> <span class="text-zinc-300">${typeof v === "object" ? JSON.stringify(v).slice(0,80) : v}</span></div>`).join("")}
        </div>
        <div class="mt-2 text-xs text-zinc-600">Score: ${score}</div>
      </div>`;
    }).join("");
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("search-btn").addEventListener("click", async () => {
      const q = document.getElementById("query-input").value.trim();
      const coll = document.getElementById("collection-select").value;
      if (!q) return;
      const data = await apiGet(`/api/memory/search?collection=${coll}&q=${encodeURIComponent(q)}&limit=10`);
      renderResults(data, `Busqueda en ${coll}`);
    });

    document.getElementById("recall-btn").addEventListener("click", async () => {
      const q = document.getElementById("recall-input").value.trim();
      if (!q) return;
      const data = await apiGet(`/api/runtime/recall?q=${encodeURIComponent(q)}&limit=8`);
      renderResults(data, "Recall Cruzado");
    });

    document.getElementById("incident-btn").addEventListener("click", async () => {
      const q = document.getElementById("incident-input").value.trim();
      const sev = document.getElementById("severity-select").value;
      let path = `/api/incidents/search?q=${encodeURIComponent(q || "error")}&limit=15`;
      if (sev) path += `&severity=${sev}`;
      const data = await apiGet(path);
      renderResults(data, "Incidentes" + (sev ? ` (${sev})` : ""));
    });

    document.getElementById("query-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("search-btn").click();
    });
    document.getElementById("recall-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("recall-btn").click();
    });
    document.getElementById("incident-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("incident-btn").click();
    });
  });
</script>
