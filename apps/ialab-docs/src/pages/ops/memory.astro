---

import Layout from "../../layouts/Layout.astro";

  const LOCAL_API = "http://127.0.0.1:8083";
  const PUBLIC_API = "https://blog-ai-lab.labrazahome.com";
  const AUTH_HEADERS = {
    "CF-Access-Client-Id": "3093bf6c93d1c8dbb6ab65db21941ac0.access",
    "CF-Access-Client-Secret": "e54c05bb3496e0ff55c55b6af63c456aa6b7d5171a74f42aeebd3facefe30a1c"
  };

  function isPublic() {
    const h = window.location.hostname;
    return h === "ai-lab.labrazahome.com" || h.includes("pages.dev") || h.includes("cloudflare");
  }

  function apiBase() {
    return isPublic() ? PUBLIC_API : LOCAL_API;
  }

  async function apiGet(path) {
    const base = apiBase();
    const headers = isPublic() ? {} : AUTH_HEADERS;
    const url = base + path;
    const res = await fetch(url, { cache: "no-store", headers });
    return await res.json();
  }

  function renderResults(data, title) {
    document.getElementById("results-title").textContent = title;
    document.getElementById("results-count").textContent = data.count || 0;
    const list = document.getElementById("results-list");
    if (!data.results || data.results.length === 0) {
      list.innerHTML = '<p class="text-zinc-500 italic">Sin resultados</p>';
      return;
    }
    list.innerHTML = data.results.map(r => {
      const p = r.payload || {};
      const coll = r.collection || "";
      const score = r.score ? Math.round(r.score * 100) + "%" : "--";
      const time = p.timestamp ? new Date(p.timestamp * 1000).toLocaleString() : "--";
      return `<div class="rounded-xl border border-zinc-800 bg-zinc-900 p-4 text-sm">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-mono text-purple-400">${coll}</span>
          <span class="text-xs text-zinc-500">${time}</span>
        </div>
        <div class="grid grid-cols-2 gap-2 text-xs">
          ${Object.entries(p).filter(([k]) => !["timestamp","schema_version","event_type"].includes(k)).map(([k, v]) => `<div><span class="text-zinc-500">${k}:</span> <span class="text-zinc-300">${typeof v === "object" ? JSON.stringify(v).slice(0,80) : v}</span></div>`).join("")}
        </div>
        <div class="mt-2 text-xs text-zinc-600">Score: ${score}</div>
      </div>`;
    }).join("");
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("search-btn").addEventListener("click", async () => {
      const q = document.getElementById("query-input").value.trim();
      const coll = document.getElementById("collection-select").value;
      if (!q) return;
      const data = await apiGet(`/api/memory/search?collection=${coll}&q=${encodeURIComponent(q)}&limit=10`);
      renderResults(data, `Busqueda en ${coll}`);
    });

    document.getElementById("recall-btn").addEventListener("click", async () => {
      const q = document.getElementById("recall-input").value.trim();
      if (!q) return;
      const data = await apiGet(`/api/runtime/recall?q=${encodeURIComponent(q)}&limit=8`);
      renderResults(data, "Recall Cruzado");
    });

    document.getElementById("incident-btn").addEventListener("click", async () => {
      const q = document.getElementById("incident-input").value.trim();
      const sev = document.getElementById("severity-select").value;
      let path = `/api/incidents/search?q=${encodeURIComponent(q || "error")}&limit=15`;
      if (sev) path += `&severity=${sev}`;
      const data = await apiGet(path);
      renderResults(data, "Incidentes" + (sev ? ` (${sev})` : ""));
    });

    document.getElementById("query-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("search-btn").click();
    });
    document.getElementById("recall-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("recall-btn").click();
    });
    document.getElementById("incident-input").addEventListener("keydown", e => {
      if (e.key === "Enter") document.getElementById("incident-btn").click();
    });
  });
</script>
