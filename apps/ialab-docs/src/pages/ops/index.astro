---
import Layout from "../../layouts/Layout.astro";
import LiveStatusCard from "../../components/LiveStatusCard.astro";
import TerminalWidget from "../../components/TerminalWidget.astro";
import TopologyGraph from "../../components/TopologyGraph.astro";
---

<Layout title="Operations Center · AI-LAB">

<section class="space-y-10">

  <div class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 to-black p-10">
    <p class="text-sm uppercase tracking-[0.3em] text-cyan-400">
      AI-LAB Operations Center
    </p>

    <h1 class="mt-6 text-5xl font-black text-white">
      Centro Operativo del Laboratorio
    </h1>

    <p class="mt-6 max-w-4xl text-xl text-zinc-300">
      Panel privado de operación, servicios, comandos rápidos y topología del AI-LAB.
    </p>
  </div>

  <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
    <LiveStatusCard title="Router API" value="ONLINE" status="online" description="OpenAI-compatible router" />
    <LiveStatusCard title="Main LM Studio" value="ONLINE" status="online" description="Fallback activo local" />
    <LiveStatusCard title="RX9070XT" value="DEGRADED" status="warning" description="LM Studio en revisión" />
    <LiveStatusCard title="RX7900XT" value="OFFLINE" status="offline" description="Nodo apagado" />
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    <TerminalWidget
      title="AI-LAB Runtime"
      lines={[
        "$ router status",
        "> Router API: online",
        "> OpenCode: online",
        "> Primary LM Studio: Main Local",
        "> RX9070XT: degraded",
        "> RX7900XT: offline",
        "> Cloudflare Access: protected",
      ]}
    />

    <TerminalWidget
      title="Quick Commands"
      lines={[
        "$ sudo systemctl restart ialab-router-api",
        "$ sudo systemctl restart ialab-live-state",
        "$ sudo systemctl restart ialab-docs",
        "$ /opt/ai-lab/runtime/opencode_ui.sh",
        "$ docker ps",
        "$ journalctl -u ialab-router-api -f",
      ]}
    />
  </section>

  <TopologyGraph />

  <section class="rounded-3xl border border-zinc-800 bg-zinc-900 p-8">
    <h2 class="text-3xl font-black text-white">
      Servicios principales
    </h2>

    <div class="mt-8 overflow-hidden rounded-2xl border border-zinc-800">
      <table class="w-full text-left">
        <thead class="bg-zinc-950">
          <tr>
            <th class="px-6 py-4 text-cyan-400">Servicio</th>
            <th class="px-6 py-4 text-cyan-400">URL / IP</th>
            <th class="px-6 py-4 text-cyan-400">Puerto</th>
            <th class="px-6 py-4 text-cyan-400">Comando</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-zinc-800">
          <tr>
            <td class="px-6 py-4 text-white">OpenCode</td>
            <td class="px-6 py-4 text-zinc-300">192.168.1.30</td>
            <td class="px-6 py-4 text-zinc-300">4096</td>
            <td class="px-6 py-4 text-emerald-400 font-mono text-sm">/opt/ai-lab/runtime/opencode_ui.sh</td>
          </tr>

          <tr>
            <td class="px-6 py-4 text-white">Router API</td>
            <td class="px-6 py-4 text-zinc-300">192.168.1.30</td>
            <td class="px-6 py-4 text-zinc-300">8008</td>
            <td class="px-6 py-4 text-emerald-400 font-mono text-sm">sudo systemctl restart ialab-router-api</td>
          </tr>

          <tr>
            <td class="px-6 py-4 text-white">Astro Docs</td>
            <td class="px-6 py-4 text-zinc-300">blog-ai-lab.labrazahome.com</td>
            <td class="px-6 py-4 text-zinc-300">4321</td>
            <td class="px-6 py-4 text-emerald-400 font-mono text-sm">sudo systemctl restart ialab-docs</td>
          </tr>

          <tr>
            <td class="px-6 py-4 text-white">Traefik</td>
            <td class="px-6 py-4 text-zinc-300">192.168.1.30</td>
            <td class="px-6 py-4 text-zinc-300">80 / 443 / 8080</td>
            <td class="px-6 py-4 text-emerald-400 font-mono text-sm">docker restart traefik</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

</section>

</Layout>
