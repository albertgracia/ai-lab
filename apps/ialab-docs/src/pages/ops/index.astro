---
import Layout from "../../layouts/Layout.astro";

const target = "https://metricas.labrazahome.com/ops";
---

<Layout title="Operations Center · AI-LAB">
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
  </Fragment>

  <section class="mx-auto max-w-4xl px-6 py-20">
    <div class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black p-10 text-center">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB COMMAND CENTER</p>
      <h1 class="mt-4 text-5xl font-black text-white">Operations Center movido a metricas</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-zinc-300">
        La telemetria live ahora se sirve desde Next.js SSR para evitar paginas publicas vacias y mantener datos reales en runtime.
      </p>
      <a href={target} class="mt-8 inline-flex rounded-xl bg-cyan-400 px-6 py-3 text-sm font-black text-zinc-950 hover:bg-cyan-300">
        Abrir metricas.labrazahome.com/ops
      </a>
    </div>
  </section>

  <script define:vars={{ target }}>
    window.location.replace(target);
  </script>
</Layout>
