---
import Layout from "../../layouts/Layout.astro";
import ClusterHealth from "../../components/ClusterHealth.astro";
import EventStream from "../../components/EventStream.astro";
---

<Layout title="Operations Center · AI-LAB">
  <section class="mx-auto max-w-7xl px-6 py-16 space-y-10">

    <header class="rounded-3xl border border-cyan-500/30 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black p-10">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB COMMAND CENTER</p>
      <div class="mt-6 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="text-5xl font-black text-white">AI Operations Center</h1>
          <p class="mt-4 max-w-4xl text-lg leading-8 text-zinc-300">
            Centro de operaciones en tiempo real. Datos via analytics API con health score, metricas de gateway, sesiones y eventos.
          </p>
        </div>
        <div id="health-badge" class="rounded-2xl border border-zinc-700 bg-zinc-900 px-5 py-4">
          <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Health Score</p>
          <p class="mt-2 text-3xl font-black" id="health-value">--</p>
        </div>
      </div>
    </header>

    <ClusterHealth />

    <section class="grid gap-5 md:grid-cols-4" id="analytics-stats">
      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Requests</p>
        <p class="mt-2 text-2xl font-black text-cyan-400" id="stat-requests">--</p>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Sessions</p>
        <p class="mt-2 text-2xl font-black text-emerald-400" id="stat-sessions">--</p>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Latencia Media</p>
        <p class="mt-2 text-2xl font-black text-purple-400" id="stat-latency">--</p>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-sm text-zinc-500">Routing Decisions</p>
        <p class="mt-2 text-2xl font-black text-yellow-400" id="stat-routing">--</p>
      </div>
    </section>

    <div class="grid gap-6 lg:grid-cols-2">
      <EventStream />
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
        <h3 class="text-lg font-bold text-cyan-400 mb-4">Health Reasons</h3>
        <div id="health-reasons" class="space-y-2 text-sm">
          <p class="text-zinc-500 italic">Esperando datos...</p>
        </div>
      </div>
    </div>

    <section class="grid gap-5 md:grid-cols-3">
      <a href="/status/live" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        <p class="font-bold">Estado Vivo</p>
        <p class="mt-1 text-sm text-zinc-500">Monitorización en tiempo real</p>
      </a>
      <a href="/status/history" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        <p class="font-bold">Histórico</p>
        <p class="mt-1 text-sm text-zinc-500">Evolución 24h / 7d</p>
      </a>
      <a href="/status/topology" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6 text-cyan-300 hover:border-cyan-400">
        <p class="font-bold">Topología</p>
        <p class="mt-1 text-sm text-zinc-500">Mapa del cluster</p>
      </a>
    </section>
  </section>
</Layout>

<script>
  async function refreshAnalytics() {
    try {
      const res = await fetch("/api/analytics", { cache: "no-store" });
      const data = await res.json();
      
      const health = data.health || {};
      const metrics = data.metrics || {};
      const sessions = data.sessions || {};

      const score = health.score || 0;
      const el = document.getElementById("health-value");
      el.textContent = score;
      el.className = "mt-2 text-3xl font-black " + (
        score >= 80 ? "text-emerald-400" :
        score >= 60 ? "text-yellow-400" :
        score >= 40 ? "text-orange-400" : "text-red-400"
      );
      document.getElementById("health-badge").className = "rounded-2xl border px-5 py-4 " + (
        score >= 80 ? "border-emerald-500/30 bg-emerald-500/10" :
        score >= 60 ? "border-yellow-500/30 bg-yellow-500/10" :
        score >= 40 ? "border-orange-500/30 bg-orange-500/10" :
        "border-red-500/30 bg-red-500/10"
      );

      document.getElementById("stat-requests").textContent = metrics.requests_total || 0;
      document.getElementById("stat-sessions").textContent = sessions.active_sessions || 0;
      document.getElementById("stat-latency").textContent = (metrics.last_latency_ms || 0) + "ms";
      document.getElementById("stat-routing").textContent = metrics.routing_decisions_total || 0;

      const reasons = document.getElementById("health-reasons");
      if (health.reasons && health.reasons.length) {
        reasons.innerHTML = health.reasons.map(r => 
          `<div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-400 shrink-0"></span>${r}</div>`
        ).join("");
      } else {
        reasons.innerHTML = '<p class="text-emerald-400">Todos los sistemas operativos</p>';
      }
    } catch {}
  }
  refreshAnalytics();
  setInterval(refreshAnalytics, 10000);
</script>
