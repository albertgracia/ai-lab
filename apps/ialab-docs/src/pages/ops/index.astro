---
import Layout from "../../layouts/Layout.astro";
import OpsServiceCard from "../../components/OpsServiceCard.astro";

let services = [];
let generatedAt = null;

try {
  const response = await Astro.fetchContent
    ? null
    : await fetch(new URL("/api/services.json", "http://127.0.0.1:4322"));

  if (response && response.headers.get("content-type")?.includes("application/json")) {
    const data = await response.json();
    services = Array.isArray(data.services) ? data.services : [];
    generatedAt = data.generated_at;
  }
} catch (error) {
  console.error("Services API unavailable", error);
}

const online = services.filter((s) => s.status === "online").length;
const planned = services.filter((s) => s.status === "planned").length;
const total = services.length;
---

<Layout title="Operations Center · AI-LAB">
  <section class="space-y-10">

    <header class="rounded-3xl border border-cyan-500/30 bg-zinc-950/80 p-8">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-400">AI-LAB COMMAND CENTER</p>

      <div class="mt-6 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="text-5xl font-black text-white">Operations Center</h1>
          <p class="mt-4 max-w-4xl text-lg leading-8 text-zinc-300">
            Centro operacional privado para supervisar servicios, telemetría, histórico,
            runbooks y estado del laboratorio de IA.
          </p>
        </div>

        <div class="rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-5 py-4 text-emerald-300">
          <p class="text-xs uppercase tracking-[0.25em]">Operational State</p>
          <p class="mt-2 text-2xl font-black">ACTIVE</p>
        </div>
      </div>
    </header>

    <section class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6">
        <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">Services</p>
        <p class="mt-3 text-4xl font-black text-white">{total}</p>
      </div>

      <div class="rounded-2xl border border-emerald-500/20 bg-zinc-950 p-6">
        <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">Online</p>
        <p class="mt-3 text-4xl font-black text-emerald-300">{online}</p>
      </div>

      <div class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-6">
        <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">Planned</p>
        <p class="mt-3 text-4xl font-black text-cyan-300">{planned}</p>
      </div>
    </section>

    <section>
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-3xl font-black text-white">Operational Services</h2>
          <p class="mt-2 text-zinc-400">Mapa base de servicios internos del laboratorio.</p>
        </div>

        {generatedAt && (
          <p class="text-xs text-zinc-500">
            Generated: {generatedAt}
          </p>
        )}
      </div>

      <div class="grid gap-5 lg:grid-cols-2">
        {services.map((service) => (
          <OpsServiceCard service={service} />
        ))}
      </div>
    </section>

    <section class="rounded-3xl border border-cyan-500/20 bg-black/40 p-8">
      <h2 class="text-3xl font-black text-white">Next Actions</h2>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <a href="/status/live" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-5 text-cyan-300 hover:border-cyan-400">
          Ver Estado Vivo →
        </a>

        <a href="/status/history" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-5 text-cyan-300 hover:border-cyan-400">
          Ver Histórico →
        </a>

        <a href="/runbooks" class="rounded-2xl border border-cyan-500/20 bg-zinc-950 p-5 text-cyan-300 hover:border-cyan-400">
          Abrir Runbooks →
        </a>
      </div>
    </section>

  </section>
</Layout>
