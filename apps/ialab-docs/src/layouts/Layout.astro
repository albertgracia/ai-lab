---
import "../styles/global.css";

const { title = "AI-LAB" } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

</head>

<body class="bg-black text-white font-[Inter]">

  <div class="min-h-screen flex">

    <!-- SIDEBAR -->

    <aside class="w-[300px] border-r border-zinc-800 bg-black/90 backdrop-blur sticky top-0 h-screen flex flex-col justify-between">

      <div>

        <!-- LOGO -->

        <div class="p-6 border-b border-zinc-800">

          <a href="/" class="block">

            <div class="flex items-center gap-4">

              <img
                src="/images/ai-lab-logo.png"
                alt="AI-LAB"
                class="h-48 w-auto mx-auto"
              />


            </div>

        <!-- NAVIGATION -->

        <nav class="p-5 space-y-2 text-lg">

          <a
            href="/"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Inicio
          </a>

          <a
            href="/architecture"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Arquitectura
          </a>

          <a
            href="/projects"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Proyectos
          </a>

          <a
            href="/skills"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Skills
          </a>

          <a
            href="/docs"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Documentación
          </a>

          <a
            href="/blog"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Blog Técnico
          </a>

          <a
            href="/runbooks"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Runbooks
          </a>

          <a
            href="/services"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Servicios
          </a>

          <a
            href="/ops"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Operations Center
          </a>

          <a
            href="/status"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Estado Vivo
          </a>

          <a
            href="/status/live"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            AI-LAB NOC
          </a>

          <a
            href="/status/history"
            class="block rounded-xl px-4 py-3 text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400 transition"
          >
            Historical Telemetry
          </a>

        </nav>

      </div>

      <!-- FOOTER -->

      <div class="p-5">

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-5">

          <p class="text-xs uppercase tracking-[0.3em] text-zinc-500">
            Runtime
          </p>

          <div class="mt-4 space-y-2 text-lg">

            <div class="text-zinc-300">
              Router · GPUs · Docker · OpenCode
            </div>

            <div class="flex items-center gap-2 text-green-400 text-sm">

              <div class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></div>

              <span>
                Operational
              </span>

            </div>

          </div>

        </div>

      </div>

    </aside>

    <!-- CONTENT -->

    <main class="flex-1 overflow-x-hidden">

      <div class="mx-auto max-w-7xl px-10 py-10">

        <slot />

      </div>

    </main>

  </div>

</body>

</html>
