---
const {
  label,
  value = 0,
  max = 100,
} = Astro.props;

const percent = Math.min(
  100,
  Math.round((value / max) * 100)
);
---

<div class="space-y-2">

  <div class="flex justify-between text-sm">
    <span class="text-zinc-300">{label}</span>
    <span class="text-cyan-400">{value} / {max}</span>
  </div>

  <div class="h-3 overflow-hidden rounded-full bg-zinc-800">

    <div
      class="h-full rounded-full bg-cyan-400 transition-all duration-500"
      style={`width:${percent}%`}
    />

  </div>

</div>
