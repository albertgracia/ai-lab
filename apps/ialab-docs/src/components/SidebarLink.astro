---
const {
  href,
  label,
  icon: Icon,
} = Astro.props;

const current = Astro.url.pathname;

const active =
  current === href ||
  current.startsWith(href + "/");
---

<a
  href={href}
  class={`group flex items-center gap-3 rounded-2xl px-4 py-3 transition-all duration-200
  ${
    active
      ? "bg-cyan-500/10 text-cyan-400 border border-cyan-500/30 shadow-[0_0_25px_rgba(34,211,238,0.12)]"
      : "text-zinc-300 hover:bg-zinc-900 hover:text-cyan-400"
  }`}
>

  <div class="opacity-80 group-hover:opacity-100">
    <Icon class="h-5 w-5" />
  </div>

  <span class="font-medium tracking-tight">
    {label}
  </span>

</a>
