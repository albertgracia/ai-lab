---
const {
  title,
  value,
  status = "online",
  description = "",
} = Astro.props;

const statusColor = {
  online: "bg-green-500",
  warning: "bg-yellow-500",
  offline: "bg-red-500",
}[status];
---

<div class="group rounded-3xl border border-zinc-800 bg-zinc-900/80 p-6 transition hover:border-cyan-400/40 hover:bg-zinc-900">

  <div class="flex items-center justify-between">

    <h3 class="text-lg font-semibold text-zinc-300">
      {title}
    </h3>

    <div class={`h-3 w-3 rounded-full ${statusColor} animate-pulse`}></div>

  </div>

  <div class="mt-6">

    <div class="text-4xl font-black tracking-tight text-white">
      {value}
    </div>

    {
      description && (
        <p class="mt-3 text-sm text-zinc-500">
          {description}
        </p>
      )
    }

  </div>

</div>
