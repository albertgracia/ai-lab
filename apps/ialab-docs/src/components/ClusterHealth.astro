---
// ClusterHealth.astro - Live cluster health via SSE
---

<div class="grid gap-4 md:grid-cols-5" id="cluster-health-astro">
  <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm text-zinc-500">GPUs</p>
    <p class="mt-2 text-3xl font-black text-cyan-400" id="stat-gpus">--</p>
  </div>
  <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm text-zinc-500">Docker</p>
    <p class="mt-2 text-3xl font-black text-emerald-400" id="stat-docker">--</p>
  </div>
  <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm text-zinc-500">VRAM Usada</p>
    <p class="mt-2 text-3xl font-black text-purple-400" id="stat-vram">--</p>
  </div>
  <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm text-zinc-500">VRAM Libre</p>
    <p class="mt-2 text-3xl font-black text-emerald-400" id="stat-vram-free">--</p>
  </div>
  <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm text-zinc-500">Estado</p>
    <p class="mt-2 text-3xl font-black text-red-400" id="stat-status">OFF</p>
  </div>
</div>

<script>
  async function refresh() {
    try {
      const res = await fetch("/api/status.json", { cache: "no-store" });
      const data = await res.json();
      const gpu = Array.isArray(data.gpu) ? data.gpu : [];
      const docker = Array.isArray(data.docker?.containers) ? data.docker.containers : [];
      const gpuOnline = gpu.filter((g) => g.vram_total_gib > 0).length;
      const dockerRunning = docker.filter((c) => c.State === "running").length;
      const vramUsed = gpu.reduce((a, g) => a + (g.vram_used_gib || 0), 0);
      const vramTotal = gpu.reduce((a, g) => a + (g.vram_total_gib || 0), 0);
      document.getElementById("stat-gpus").textContent = `${gpuOnline}/${gpu.length}`;
      document.getElementById("stat-docker").textContent = `${dockerRunning}/${docker.length}`;
      document.getElementById("stat-vram").textContent = `${vramUsed.toFixed(1)} GiB`;
      document.getElementById("stat-vram-free").textContent = `${(vramTotal - vramUsed).toFixed(1)} GiB`;
      document.getElementById("stat-status").textContent = "LIVE";
      document.getElementById("stat-status").className = "mt-2 text-3xl font-black text-emerald-400";
    } catch {
      document.getElementById("stat-status").textContent = "OFF";
      document.getElementById("stat-status").className = "mt-2 text-3xl font-black text-red-400";
    }
  }
  refresh();
  setInterval(refresh, 5000);
</script>
