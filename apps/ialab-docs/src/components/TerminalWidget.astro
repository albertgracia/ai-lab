---
const {
  title = "AI-LAB Runtime",
  lines = [],
} = Astro.props;
---

<div class="overflow-hidden rounded-3xl border border-cyan-500/20 bg-black shadow-2xl">

  <div class="flex items-center gap-2 border-b border-zinc-800 bg-zinc-950 px-5 py-3">

    <div class="h-3 w-3 rounded-full bg-red-500"></div>
    <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
    <div class="h-3 w-3 rounded-full bg-green-500"></div>

    <div class="ml-4 text-sm text-zinc-500">
      {title}
    </div>

  </div>

  <div class="space-y-2 p-6 font-mono text-sm text-cyan-400">

    {
      lines.map((line) => (
        <div>{line}</div>
      ))
    }

  </div>

</div>
