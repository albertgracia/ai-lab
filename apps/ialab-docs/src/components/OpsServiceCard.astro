---
const { service } = Astro.props;

const statusStyles = {
  online: "border-emerald-500/40 bg-emerald-500/10 text-emerald-300",
  degraded: "border-yellow-500/40 bg-yellow-500/10 text-yellow-300",
  offline: "border-red-500/40 bg-red-500/10 text-red-300",
  planned: "border-cyan-500/40 bg-cyan-500/10 text-cyan-300",
};

const label = {
  online: "ONLINE",
  degraded: "DEGRADED",
  offline: "OFFLINE",
  planned: "PLANNED",
}[service.status] ?? "UNKNOWN";
---

<a href={service.url} class="block rounded-2xl border border-cyan-500/20 bg-zinc-950/80 p-6 transition hover:border-cyan-400/60 hover:bg-cyan-950/20">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-cyan-400">{service.category}</p>
      <h3 class="mt-3 text-xl font-bold text-white">{service.name}</h3>
    </div>

    <span class={`rounded-full border px-3 py-1 text-xs font-bold ${statusStyles[service.status] ?? "border-zinc-500/40 bg-zinc-500/10 text-zinc-300"}`}>
      {label}
    </span>
  </div>

  <p class="mt-4 text-sm leading-6 text-zinc-400">
    {service.description}
  </p>
</a>
