---
// EventStream.astro - Live event stream via SSE
---

<div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-bold text-cyan-400">Event Stream</h3>
    <span id="sse-status" class="px-2 py-1 text-xs rounded-full bg-red-500/20 text-red-400">OFFLINE</span>
  </div>
  <div id="event-list" class="space-y-1 max-h-60 overflow-y-auto font-mono text-xs">
    <p class="text-zinc-500 italic">Esperando eventos...</p>
  </div>
</div>

<script>
  const list = document.getElementById("event-list");
  const status = document.getElementById("sse-status");
  const es = new EventSource("/api/events");
  let count = 0;

  es.onmessage = (msg) => {
    try {
      const evt = JSON.parse(msg.data);
      count++;
      status.textContent = "LIVE";
      status.className = "px-2 py-1 text-xs rounded-full bg-emerald-500/20 text-emerald-400";

      const div = document.createElement("div");
      div.className = "flex gap-2 text-xs";
      if (evt.event === "heartbeat") div.className += " opacity-40";

      const ts = evt.data?.ts ? new Date(evt.data.ts * 1000).toLocaleTimeString() : new Date().toLocaleTimeString();
      div.innerHTML = `<span class="text-zinc-500 shrink-0">${ts}</span>
        <span class="shrink-0 ${evt.event === "heartbeat" ? "text-cyan-400" : "text-emerald-400"}">${evt.event}</span>
        <span class="text-zinc-400 truncate">${JSON.stringify(evt.data).slice(0, 80)}</span>`;

      list.prepend(div);
      if (list.children.length > 50) list.removeChild(list.lastChild);
    } catch {}
  };

  es.onerror = () => {
    status.textContent = "OFFLINE";
    status.className = "px-2 py-1 text-xs rounded-full bg-red-500/20 text-red-400";
  };
</script>
