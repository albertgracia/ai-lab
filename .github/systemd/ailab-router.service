[Unit]
Description=AI-LAB Cognitive Router API
After=network-online.target ailab-gateway.service
Wants=network-online.target

[Service]
Type=simple
User=albert
WorkingDirectory=/opt/ai-lab
Environment=PYTHONPATH=/opt/ai-lab
ExecStart=/opt/ai-lab/.venv/bin/uvicorn runtime.llm.router_api:app --host 0.0.0.0 --port 8083
Restart=always
RestartSec=5
MemoryMax=256M

[Install]
WantedBy=multi-user.target
