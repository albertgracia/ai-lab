{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://192.168.1.50:1234/v1"
      },
      "models": {
        "qwen2.5-coder-14b-instruct": {
          "name": "Qwen 2.5 Coder 14B Instruct"
        },
        "qwen3-14b-claude-sonnet-4.5-reasoning-distill": {
          "name": "Qwen3 14B Reasoning Distill"
        },
        "google/gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        }
      }
    },
    "ailab-router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AI-LAB Router",
      "options": {
        "baseURL": "http://192.168.1.30:8083/v1"
      },
      "models": {
        "auto": {
          "name": "AI-LAB Router (auto)"
        },
        "fast": {
          "name": "AI-LAB Router (fast)"
        },
        "reasoning": {
          "name": "AI-LAB Router (reasoning)"
        },
        "coding": {
          "name": "AI-LAB Router (coding)"
        }
      }
    }
  },
  "agentRoot": ".agent",
  "bootstrap": ".agent/BOOTSTRAP.md",
  "rules": [
    ".agent/rules/GEMINI.md"
  ],
  "agents": ".agent/agents",
  "skills": ".agent/skills",
  "workflows": ".agent/workflows",
  "memory": "memory/semantic/ai-lab-architecture.md"
}
