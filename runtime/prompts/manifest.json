    "chat": ["HARD_FACTS", "follow_ups", "Plan Mode", "CRITICAL:", "STRICTLY FORBIDDEN", "FORMATO OBLIGATORIO"],
    "coding": ["HARD_FACTS", "follow_ups", "Plan Mode", "CRITICAL:", "STRICTLY FORBIDDEN"],
